<Window x:Class="HardwareInserter.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inserción de tornillería" Height="500" Width="900">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Cargar Excel" Command="{Binding CargarExcelCommand}" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Seleccionar Agujero" Command="{Binding SeleccionarAgujeroCommand}" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock Text="{Binding DiametroDetectadoMm, StringFormat='Ø detectado: {0:0.##} mm'}"
                       VerticalAlignment="Center" Margin="8,0,0,0" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" TextWrapping="Wrap" />

        <DataGrid ItemsSource="{Binding Filas}" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Tipo" SelectedItemBinding="{Binding Tipo, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding Tipos}" Width="120" />
                <DataGridComboBoxColumn Header="Metrica" SelectedItemBinding="{Binding Metrica, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding Metricas}" Width="100" />
                <DataGridComboBoxColumn Header="Longitud" SelectedItemBinding="{Binding Longitud, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding Longitudes}" Width="100" />
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="80" />
                <DataGridTextColumn Header="Referencia" Binding="{Binding Referencia}" Width="150" />
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Detalle" Binding="{Binding Detalle}" Width="*" IsReadOnly="True" />
                <DataGridTemplateColumn Header="" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Insertar" Padding="4,2"
                                    Command="{Binding DataContext.InsertarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
